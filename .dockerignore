# Ignore node_modules directory to prevent copying unnecessary dependencies
node_modules

# Ignore local editor settings
.vscode

# Ignore Git repository files
.git

# Ignore build folder
dist
build

# Ignore ESLint, Prettier, and other configuration files that aren't needed in the final image
.eslint*
.prettier*
.editorconfig
.DS_Store

#Ignore environment variable files
# .env is intentionally not ignored to allow for environment variable configuration in the container
.env.prod
.env.local
.env.development
.env.test
.env.production